{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://models-cn.dev/schema/v1/provider.schema.json",
  "title": "models-cn provider data",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "ownedBy",
    "baseUrls",
    "health",
    "models",
    "sources"
  ],
  "properties": {
    "schemaVersion": { "const": "2.0" },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "displayNames": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zh-CN", "en"],
      "properties": {
        "zh-CN": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      }
    },
    "ownedBy": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "baseUrls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["openai"],
      "properties": {
        "openai": { "type": "string", "format": "uri" },
        "anthropic": { "type": "string", "format": "uri" }
      }
    },
    "health": { "$ref": "#/$defs/health" },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/model" }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    }
  },
  "$defs": {
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "lastSuccessfulAt",
        "lastAttemptAt",
        "consecutiveFailures"
      ],
      "properties": {
        "status": { "enum": ["healthy", "stale", "error"] },
        "lastSuccessfulAt": { "type": "string", "format": "date-time" },
        "lastAttemptAt": { "type": "string", "format": "date-time" },
        "consecutiveFailures": { "type": "integer", "minimum": 0 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "kind", "locale", "retrievedAt", "contentHash"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "kind": { "enum": ["pricing", "model-metadata"] },
        "locale": { "enum": ["zh-CN", "en"] },
        "currency": { "enum": ["CNY", "USD"] },
        "retrievedAt": { "type": "string", "format": "date-time" },
        "contentHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "alias": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mode"],
      "properties": {
        "id": { "type": "string" },
        "mode": { "enum": ["thinking", "non-thinking"] },
        "deprecatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "price": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "market",
        "currency",
        "unit",
        "rateType",
        "input",
        "output",
        "sourceUrl"
      ],
      "properties": {
        "market": { "enum": ["china", "international"] },
        "currency": { "enum": ["CNY", "USD"] },
        "unit": { "const": "1M_tokens" },
        "rateType": { "enum": ["standard", "promotional"] },
        "inputTokenRange": {
          "type": "object",
          "additionalProperties": false,
          "required": ["label"],
          "properties": {
            "label": { "type": "string", "minLength": 1 },
            "minExclusive": { "type": "integer", "minimum": 0 },
            "maxInclusive": { "type": "integer", "minimum": 1 }
          }
        },
        "input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["standard"],
          "properties": {
            "standard": {
              "type": "number",
              "minimum": 0,
              "description": "Standard input price. This applies to all input tokens unless cacheHit is explicitly provided and applicable."
            },
            "cacheHit": {
              "type": "number",
              "minimum": 0,
              "description": "Optional cached-input price, present only when the provider explicitly defines a cache-hit billing rule."
            }
          }
        },
        "output": { "type": "number", "minimum": 0 },
        "sourceUrl": { "type": "string", "format": "uri" }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "aliases", "capabilities", "limits", "prices"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "name": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "tokenizer": { "type": "string", "minLength": 1 },
        "aliases": { "type": "array", "items": { "$ref": "#/$defs/alias" } },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "thinking": { "type": "boolean" },
            "thinkingModes": {
              "type": "array",
              "items": { "enum": ["thinking", "non-thinking"] },
              "uniqueItems": true
            },
            "reasoningEfforts": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "dynamicTools": { "type": "boolean" },
            "jsonOutput": { "type": "boolean" },
            "toolCalls": { "type": "boolean" },
            "chatPrefixCompletion": { "type": "boolean" },
            "fimCompletion": {
              "enum": ["non-thinking-only", "supported", "unsupported"]
            },
            "inputModalities": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "outputModalities": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "supportedParameters": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            }
          },
          "minProperties": 1
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["contextTokens"],
          "properties": {
            "contextTokens": { "type": "integer", "minimum": 1 },
            "maxOutputTokens": { "type": "integer", "minimum": 1 },
            "concurrency": { "type": "integer", "minimum": 1 }
          }
        },
        "prices": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/price" }
        }
      }
    }
  }
}
