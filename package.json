{
  "name": "models-cn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "collect": "tsx src/cli/collect.ts",
    "discover": "tsx src/cli/discover.ts",
    "update": "npm run collect && npm run discover && npm run build",
    "site:dev": "vite --config vite.config.ts",
    "site:build": "vite build --config vite.config.ts",
    "site:preview": "vite preview --config vite.config.ts",
    "build": "tsx src/cli/build.ts",
    "validate": "tsx src/cli/validate.ts",
    "check": "npm run typecheck && npm test && npm run validate",
    "typecheck": "tsc --noEmit && tsc --noEmit -p site/tsconfig.json",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cheerio": "^1.2.0",
    "domhandler": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "prettier": "^3.9.6",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  }
}
